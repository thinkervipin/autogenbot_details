<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AUTOGENBOT - Democratizing Outdoor Autonomy</title>
    <meta name="description" content="Field-tested autonomous platforms for agriculture and defense. Angel round open now.">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Goldman:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --primary: #10b981;
            --primary-dark: #059669;
            --accent: #22c55e;
            --bg-dark: #0a0a0a;
            --bg-card: #141414;
            --text-primary: #ffffff;
            --text-secondary: #a3a3a3;
            --border: #1f1f1f;
            
            --font-display: 'Goldman', system-ui, sans-serif;
            --font-body: 'Inter', system-ui, sans-serif;
        }
        
        body {
            font-family: var(--font-body);
            background: var(--bg-dark);
            color: var(--text-primary);
            min-height: 100vh;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
            position: relative;
        }
        
        /* Wireframe/Blueprint Background */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(16, 185, 129, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(16, 185, 129, 0.02) 1px, transparent 1px),
                linear-gradient(rgba(16, 185, 129, 0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(16, 185, 129, 0.04) 1px, transparent 1px),
                repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(16, 185, 129, 0.01) 35px, rgba(16, 185, 129, 0.01) 70px);
            background-size: 
                20px 20px,
                20px 20px,
                100px 100px,
                100px 100px,
                70px 70px;
            z-index: -2;
            opacity: 0.6;
        }
        
        body::after {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image:
                radial-gradient(circle at 10% 10%, transparent 30%, rgba(16, 185, 129, 0.02) 30%, rgba(16, 185, 129, 0.02) 30.5%, transparent 30.5%),
                radial-gradient(circle at 90% 10%, transparent 30%, rgba(16, 185, 129, 0.02) 30%, rgba(16, 185, 129, 0.02) 30.5%, transparent 30.5%),
                radial-gradient(circle at 10% 90%, transparent 30%, rgba(16, 185, 129, 0.02) 30%, rgba(16, 185, 129, 0.02) 30.5%, transparent 30.5%),
                radial-gradient(circle at 90% 90%, transparent 30%, rgba(16, 185, 129, 0.02) 30%, rgba(16, 185, 129, 0.02) 30.5%, transparent 30.5%);
            background-size: 200px 200px;
            background-repeat: no-repeat;
            z-index: -2;
            opacity: 0.4;
        }
        
        .bg-gradient {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            opacity: 0.08;
            background: 
                radial-gradient(circle at 20% 50%, var(--primary) 0%, transparent 40%),
                radial-gradient(circle at 80% 80%, var(--accent) 0%, transparent 40%),
                radial-gradient(circle at 50% 20%, var(--primary) 0%, transparent 30%);
            animation: gradientShift 15s ease infinite;
        }
        
        @keyframes gradientShift {
            0%, 100% { 
                transform: translate(0, 0) scale(1) rotate(0deg);
                opacity: 0.08;
            }
            33% { 
                transform: translate(30px, -20px) scale(1.05) rotate(2deg);
                opacity: 0.12;
            }
            66% { 
                transform: translate(-20px, 30px) scale(0.98) rotate(-2deg);
                opacity: 0.1;
            }
        }
        
        .bg-gradient::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
            animation: scan 8s linear infinite;
            opacity: 0.3;
        }
        
        @keyframes scan {
            0% { transform: translateY(0); }
            100% { transform: translateY(100vh); }
        }
        
        .container {
            max-width: 700px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        header {
            padding: 50px 0 40px;
            text-align: center;
            border-bottom: 1px solid var(--border);
            margin-bottom: 40px;
        }
        
        .logo {
            font-family: var(--font-display);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 5px;
            color: var(--text-secondary);
            text-transform: uppercase;
            margin-bottom: 25px;
            text-shadow: 0 0 10px rgba(16, 185, 129, 0.2);
        }
        
        h1 {
            font-family: var(--font-display);
            font-size: clamp(2.2rem, 8vw, 3.5rem);
            font-weight: 700;
            line-height: 1.1;
            margin-bottom: 20px;
            letter-spacing: -0.01em;
            color: var(--text-primary);
            text-shadow: 0 0 30px rgba(16, 185, 129, 0.15);
        }
        
        .tagline {
            font-size: 1.1rem;
            color: var(--text-secondary);
            font-weight: 300;
            line-height: 1.6;
            margin-bottom: 25px;
        }
        
        .tagline strong {
            color: var(--primary);
            font-weight: 600;
        }
        
        /* Pulsing Urgency Banner */
        .urgency-banner {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            padding: 18px 24px;
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(34, 197, 94, 0.1) 100%);
            border: 1px solid var(--primary);
            border-radius: 10px;
            margin: 25px auto;
            max-width: 600px;
            animation: urgencyPulse 2.5s ease-in-out infinite;
            position: relative;
            overflow: hidden;
        }
        
        .urgency-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(16, 185, 129, 0.1), transparent);
            animation: shimmer 3s linear infinite;
        }
        
        @keyframes urgencyPulse {
            0%, 100% { 
                transform: scale(1); 
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
            }
            50% { 
                transform: scale(1.02); 
                box-shadow: 0 0 20px 0 rgba(16, 185, 129, 0.3);
            }
        }
        
        @keyframes shimmer {
            0% { transform: translate(-50%, -50%) rotate(0deg); }
            100% { transform: translate(-50%, -50%) rotate(360deg); }
        }
        
        .urgency-icon {
            font-size: 28px;
            animation: lightning 2s ease-in-out infinite;
            position: relative;
            z-index: 1;
        }
        
        @keyframes lightning {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.6; transform: scale(1.1); }
        }
        
        .urgency-main {
            font-family: var(--font-display);
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--primary);
            letter-spacing: 0.5px;
            position: relative;
            z-index: 1;
            text-transform: uppercase;
        }
        
        .urgency-sub {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-primary);
            letter-spacing: 0.3px;
            position: relative;
            z-index: 1;
        }
        
        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin: 30px 0;
        }
        
        .stat {
            text-align: center;
        }
        
        .stat-value {
            font-family: var(--font-display);
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 5px;
            text-shadow: 0 0 20px rgba(16, 185, 129, 0.3);
            transition: all 0.3s ease;
        }
        
        .stat:hover .stat-value {
            transform: scale(1.05);
            text-shadow: 0 0 30px rgba(16, 185, 129, 0.5);
        }
        
        .stat-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .badges {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 16px;
            margin-top: 35px;
            max-width: 650px;
            margin-left: auto;
            margin-right: auto;
        }
        
        .badge {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            padding: 16px 12px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: center;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .badge::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        
        .badge:hover::before {
            transform: scaleX(1);
        }
        
        .badge:hover {
            border-color: var(--primary);
            color: var(--primary);
            box-shadow: 0 0 20px rgba(16, 185, 129, 0.3);
            transform: translateY(-3px);
            background: rgba(16, 185, 129, 0.05);
        }
        
        .badge-icon {
            font-size: 36px;
            line-height: 1;
            filter: drop-shadow(0 0 8px rgba(16, 185, 129, 0.3));
            transition: all 0.3s ease;
        }
        
        .badge:hover .badge-icon {
            transform: scale(1.15);
            filter: drop-shadow(0 0 15px rgba(16, 185, 129, 0.6));
        }
        
        .badge-text {
            font-size: 0.65rem;
            line-height: 1.3;
        }
        
        main {
            padding: 30px 0 50px;
        }
        
        .cta-primary {
            display: block;
            width: 100%;
            padding: 22px 30px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            border: none;
            border-radius: 10px;
            color: white;
            font-family: var(--font-display);
            font-size: 1.2rem;
            font-weight: 700;
            text-decoration: none;
            text-align: center;
            margin-bottom: 15px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 20px rgba(16, 185, 129, 0.3);
            position: relative;
            overflow: hidden;
        }
        
        .cta-primary::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }
        
        .cta-primary:hover::before {
            left: 100%;
        }
        
        .cta-primary:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 12px 40px rgba(16, 185, 129, 0.5),
                        0 0 30px rgba(16, 185, 129, 0.3);
            background: linear-gradient(135deg, var(--accent) 0%, var(--primary) 100%);
        }
        
        .cta-subtitle {
            text-align: center;
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 30px;
        }
        
        .links {
            display: grid;
            gap: 10px;
            margin-top: 20px;
        }
        
        .link-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 16px 20px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            text-decoration: none;
            color: var(--text-primary);
            font-size: 0.95rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        
        .link-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 3px;
            height: 100%;
            background: linear-gradient(180deg, var(--primary), var(--accent));
            transform: scaleY(0);
            transition: transform 0.3s ease;
        }
        
        .link-item:hover::before {
            transform: scaleY(1);
        }
        
        .link-item:hover {
            border-color: var(--primary);
            background: rgba(16, 185, 129, 0.05);
            transform: translateX(5px);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.15);
        }
        
        .link-item:hover .link-icon {
            transform: scale(1.2) rotate(5deg);
        }
        
        .link-icon {
            font-size: 20px;
            transition: transform 0.3s ease;
        }
        
        footer {
            margin-top: 50px;
            padding: 30px 0;
            border-top: 1px solid var(--border);
            text-align: center;
        }
        
        .why-now {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 25px;
            margin-bottom: 30px;
            text-align: left;
            transition: all 0.3s ease;
        }
        
        .why-now:hover {
            border-color: rgba(16, 185, 129, 0.3);
            box-shadow: 0 0 30px rgba(16, 185, 129, 0.1);
        }
        
        .why-title {
            font-family: var(--font-display);
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 15px;
            text-shadow: 0 0 15px rgba(16, 185, 129, 0.2);
        }
        
        .why-list {
            list-style: none;
            padding: 0;
        }
        
        .why-list li {
            padding: 8px 0 8px 25px;
            position: relative;
            font-size: 0.9rem;
            color: var(--text-secondary);
            line-height: 1.5;
        }
        
        .why-list li::before {
            content: '✓';
            position: absolute;
            left: 0;
            color: var(--primary);
            font-weight: 700;
        }
        
        .funding-box {
            text-align: center;
            margin-bottom: 25px;
        }
        
        .funding-amount {
            font-family: var(--font-display);
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 8px;
        }
        
        .funding-details {
            font-size: 0.85rem;
            color: var(--text-secondary);
            line-height: 1.6;
        }
        
        .physical-ai {
            font-size: 1.1rem;
            font-weight: 500;
            color: var(--text-primary);
            margin-bottom: 20px;
            line-height: 1.6;
        }
        
        .physical-ai strong {
            color: var(--primary);
        }
        
        .footer-links {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin-top: 20px;
        }
        
        .footer-link {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.8rem;
            transition: color 0.3s ease;
        }
        
        .footer-link:hover {
            color: var(--primary);
        }
        
        @media (max-width: 600px) {
            .stats {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            
            .stat-value {
                font-size: 1.8rem;
            }
            
            h1 {
                font-size: 2rem;
            }
            
            .tagline {
                font-size: 1rem;
            }
            
            .urgency-main {
                font-size: 1.1rem;
            }
            
            .urgency-sub {
                font-size: 0.75rem;
            }
            
            .badges {
                grid-template-columns: repeat(2, 1fr);
                gap: 12px;
            }
            
            .badge {
                padding: 14px 10px;
            }
            
            .badge-icon {
                font-size: 32px;
            }
            
            .badge-text {
                font-size: 0.6rem;
            }
        }
    </style>
</head>
